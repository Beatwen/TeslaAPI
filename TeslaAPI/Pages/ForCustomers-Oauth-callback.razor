@page "/oauth-callback-old"
@using System.Net.Http;
@using System.Text.Json;
@using System.Net.Http.Headers;
@using System.Threading.Tasks;
@using System.Net;
@using TeslaAPI.Component;
@using System.Diagnostics;


<h3>Tesla Control Test</h3>
<button @onclick="GetTeslaCode">Get Tesla Code</button>
<p>@response</p>
<button @onclick="GetTags">Get Tesla Tag</button>
<p>@Tags</p>

@code {
    string response = "Response will be shown here";
    string Tags = "Tags will be shown here";
    [Inject]
    private NavigationManager? NavigationManager { get; set; }
    private HttpClient _httpClient; // HttpClient instance for making API requests
    string? token;
    string? accessToken;
    string redirectUrl = "https://a2eb-2a02-2788-11c4-afd-2551-67e-65bb-b865.ngrok-free.app/oauth-callback";

    async Task GetTeslaCode()
    {
        // Step 1: Generate code verifier, code challenge, and state
        string codeVerifier = Code.GenerateRandomString(86);
        string codeChallenge = Code.Base64UrlEncode(Code.Sha256(codeVerifier));
        string state = Code.GenerateRandomString(32);


        // Step 2: Build the authorization URL
        string authorizeUrl = $"https://auth.tesla.com/oauth2/v3/authorize?&client_id=285b750b0c21-49a2-a9af-c44c1f100566&locale=en-US&prompt=login&redirect_uri={redirectUrl}&response_type=code&scope=openid%20user_data%20vehicle_device_data%20offline_access%20vehicle_cmds%20vehicle_charging_cmds&state={state}";

        // Step 3: Create an HttpClient and add the ngrok-skip-browser-warning header
        using (var client = new HttpClient())
        {
            client.DefaultRequestHeaders.Add("ngrok-skip-browser-warning", "true");

            // Debugging: Log the headers before making the request
            foreach (var header in client.DefaultRequestHeaders)
            {
                Debug.Print($"Request Header: {header.Key}: {string.Join(", ", header.Value)}");
            }
            // Navigate the user to the Tesla login page
            NavigationManager.NavigateTo(authorizeUrl); // This line navigates the user to Tesla's login page
        }
    }
    protected override async Task OnInitializedAsync()
    {
        var uri = new Uri(NavigationManager.Uri);
        Debug.Print("URI: " + uri);
        var code = System.Web.HttpUtility.ParseQueryString(uri.Query).Get("code");
        Debug.Print("Code: " + code);
        string expectedCallbackUrl = "https://a2eb-2a02-2788-11c4-afd-2551-67e-65bb-b865.ngrok-free.app/oauth-callback";

        if (!string.IsNullOrWhiteSpace(code) && uri.AbsoluteUri.StartsWith(expectedCallbackUrl))
        {
            // Debugging: Log the successful callback
            Debug.Print("OAuth callback successful.");
            // You have the authorization code, proceed with token exchange
            token = await ExchangeAuthorizationCodeForToken(code);
           
            Debug.Print("le token " + token);
            if (!string.IsNullOrWhiteSpace(token))
            {
                response = "Access Token: " + token;
                Debug.Print("ouiii" + token);
            }
            else
            {
                response = "Token exchange failed.";
            }
        }
        else
        {
            // Debugging: Log the failed callback
            Debug.Print("OAuth callback failed.");
            response = "Authorization failed or state mismatch.";
        }
    }
    async Task GetTags()
    {
        string accessTokenJSON = token;
        accessToken = GetAccessTokenValue(accessTokenJSON);
        Debug.Print("access Token = " + accessToken);
        var GetTag = new GetTag(accessToken);
        string vehicleTag = await GetTag.GetVehicleId();
        if (vehicleTag != null)
        {
            Debug.Print($"Vehicle Tag: {vehicleTag}");
        }
    }
    private string GetAccessTokenValue(string accessTokenJson)
    {
        try
        {
            var jsonDocument = JsonDocument.Parse(accessTokenJson);
            var root = jsonDocument.RootElement;

            // Access the access_token property
            if (root.TryGetProperty("access_token", out var accessTokenProperty))
            {
                string accessToken = accessTokenProperty.GetString();
                return accessToken;
            }
        }
        catch (Exception ex)
        {
            Debug.Print($"Exception: {ex.Message}");
        }

        return null;
    }
    async Task<string> ExchangeAuthorizationCodeForToken(string authorizationCode)
    {
        // Replace these placeholders with your actual values
        string tokenEndpoint = "https://auth.tesla.com/oauth2/v3/token";
        string clientId = "285b750b0c21-49a2-a9af-c44c1f100566";
        string clientSecret = "ta-secret.rTLXH7fIyZwU5PTf";
        string redirectUri = "https://a2eb-2a02-2788-11c4-afd-2551-67e-65bb-b865.ngrok-free.app/oauth-callback";

        var formData = new List<KeyValuePair<string, string>>
        {
            new KeyValuePair<string, string>("grant_type", "authorization_code"),
            new KeyValuePair<string, string>("code", authorizationCode),
            new KeyValuePair<string, string>("client_id", clientId),
            new KeyValuePair<string, string>("client_secret", clientSecret),
            new KeyValuePair<string, string>("redirect_uri", redirectUri)
        };

        using (var client = new HttpClient())
        {
            var tokenRequest = new HttpRequestMessage(HttpMethod.Post, tokenEndpoint);
            tokenRequest.Content = new FormUrlEncodedContent(formData);

            var tokenResponse = await client.SendAsync(tokenRequest);

            if (tokenResponse.IsSuccessStatusCode)
            {
                var tokenJson = await tokenResponse.Content.ReadAsStringAsync();
                // Parse the JSON response to extract the access token
                // Store the access token securely for making API requests
                return tokenJson;
            }
            else
            {
                return null;
            }
        }
    }

}
