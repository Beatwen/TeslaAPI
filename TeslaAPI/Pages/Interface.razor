@page "/interface"
@using System;
@using System.Net.Http;
@using System.Threading.Tasks;
@using TeslaAPI.Component;
@using System.Diagnostics;
@using Data;
@inject IJSRuntime jsRuntime;
@inject NavigationManager NavigationManager;
@inject FavoriteCommands favoriteTasks;

<h3>Choose the commands you want to see in the home page</h3>
<MudGrid>
    @foreach (var item in favoriteTasks.BaseTasks)
    {
        <MudItem xs="6" sm="3">
            <MudButton @onclick="@(() => AddFavorite(@item))" Class="@("d-flex align-center justify-center mud-width-full py-8 " + @selected)">@item</MudButton>
        </MudItem>
        <MudItem xs="6" sm="3">
            <MudButton @onclick="@(() => AddFavorite("Close Charge Door"))" Class="d-flex align-center justify-center mud-width-full py-8">Close Charge Door</MudButton>
        </MudItem>
    }
</MudGrid>

@code {
    private List<string> TaskList = new();
    private string selected = "";
    private async Task AddFavorite(Command command)
    {
        if (favoriteTasks.Commands.Contains(command))
        {
            favoriteTasks.Commands.Remove(command);
        }
        else
        {
            favoriteTasks.Commands.Add(command);
        }

        LocalStorageService localStorageService = new LocalStorageService(jsRuntime);
        await localStorageService.SetItemAsync("FavCommands", favoriteTasks);
        Debug.Print("Command added: " + command);
        foreach(var item in favoriteTasks.Commands)
        {
            Debug.Print("Commande favorite: " + item);
        };
    }

    protected override async Task OnInitializedAsync()
    {


    }
}
