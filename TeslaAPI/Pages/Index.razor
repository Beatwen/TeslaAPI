@page "/"
@using System.Net.Http;
@using System.Text.Json;
@using System.Net.Http.Headers;
@using System.Threading.Tasks;
@using System.Net;
@using TeslaAPI.Component;
@using TeslaAPI.Data;
@using System.Diagnostics;
@using System.Text;
@using IdentityModel;
@using Microsoft.Extensions.DependencyInjection;
@using Microsoft.JSInterop;
@inject IJSRuntime jsRuntime;
@inject NavigationManager NavigationManager;

<PageTitle>Index</PageTitle>

@foreach (var item in displayFavoriteTask)
{
    <MudItem xs="6" sm="3">
        <MudButton Class="d-flex align-center justify-center mud-width-full py-8">@item</MudButton>
    </MudItem>
}

@code 
{
    string partnerToken;
    string userToken;
    List<string> displayFavoriteTask = new();
    protected override async Task OnInitializedAsync()
    {
        Debug.Print("Initialisation");
        partnerToken = await PartnerToken.GetPartnerToken(jsRuntime);
        Debug.Print("Init, le Partner Token = " + partnerToken);
        userToken = await UserToken.GetUserToken(NavigationManager, jsRuntime);
        await DisplayFavoriteTask();
    }
    private async Task DisplayFavoriteTask()
    {

        LocalStorageService localStorageService = new LocalStorageService(jsRuntime);
        FavoriteTasks favCommand = await localStorageService.GetItemAsync<FavoriteTasks>("FavCommands");
        if (favCommand == null) 
            return;

        foreach (var item in favCommand.Tasks)
        {
            displayFavoriteTask.Add(item);
            Debug.Print("Commande favorite: " + item);
        }
    }
}